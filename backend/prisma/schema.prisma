generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADM
  TECNICO
  OBSERVADOR
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum EnvironmentType {
  LOCAL
  CLOUD
  NODE
}

enum ProjectStatus {
  ATIVO
  FALHOU
  PAUSADO
}

enum DeployStatus {
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
  ROLLED_BACK
}

enum StepActionType {
  LOCAL_COMMAND
  REMOTE_SSH_COMMAND
}

// ─── Tenant (Organização) ─────────────────────────────────────────────────────

model Tenant {
  id          String        @id @default(uuid())
  name        String
  document    String?       // CNPJ or CPF
  status      TenantStatus  @default(ACTIVE)
  creditUsd   Float         @default(0) @map("credit_usd") // total circulating credits
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  users       User[]
  nodes       Node[]
  depinApps   DePINApp[]
  wallets     Wallet[]

  @@map("tenants")
}

model User {
  id           String          @id @default(uuid())
  name         String
  email        String          @unique
  passwordHash String          @map("password_hash")
  role         Role            @default(OBSERVADOR)
  isActive     Boolean         @default(true) @map("is_active")
  // Tenant membership
  tenantId     String?         @map("tenant_id")
  tenant       Tenant?         @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  resetToken   String?         @map("reset_token")
  resetExpires DateTime?       @map("reset_expires")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  deploys      DeployHistory[]
  widgets      DashboardWidget[]
  wallet       Wallet?
  nodes        Node[]
  depinApps    DePINApp[]
  inviteCodes  InviteCode[]
  auditActions AuditLog[]      @relation("AuditActor")

  @@map("users")
}

// ─── Invite Codes (Testnet onboarding) ───────────────────────────────────────

model InviteCode {
  id              String    @id @default(uuid())
  code            String    @unique
  createdByUserId String    @map("created_by_user_id")
  createdBy       User      @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  usedById        String?   @unique @map("used_by_id")
  usedAt          DateTime? @map("used_at")
  genesisUsd      Float     @default(50) @map("genesis_usd")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("invite_codes")
}

model DashboardWidget {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // SERVER_GAUGE, SERVER_STORAGE, SERVER_NETWORK, PROJECT_STATUS
  title     String
  settings  Json?    // { nodeId: "...", projectId: "...", metric: "cpu|ram" }
  x         Int      @default(0)
  y         Int      @default(0)
  w         Int      @default(1)
  h         Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("dashboard_widgets")
}

model Project {
  id                String               @id @default(uuid())
  name              String
  repoUrl           String               @map("repo_url")
  branchTarget      String               @default("main") @map("branch_target")
  environmentType   EnvironmentType      @default(LOCAL) @map("environment_type")
  status            ProjectStatus        @default(ATIVO)
  autoDeployEnabled Boolean              @default(true) @map("auto_deploy_enabled")
  lbEnabled         Boolean              @default(false) @map("lb_enabled")
  lbPort            Int?                 @map("lb_port")
  lbAppPort         Int?                 @map("lb_app_port")
  lbDomain          String?              @map("lb_domain")
  lbHealthPath      String               @default("/health") @map("lb_health_path")
  proxyHost         String?              @map("proxy_host")
  proxyPort         Int?                 @map("proxy_port")
  deployTimeoutMin  Int                  @default(10) @map("deploy_timeout_min")
  healthCheckDelay  Int                  @default(15) @map("health_check_delay")
  healthCheckUrl    String?              @map("health_check_url")
  cloudServerId     String?              @map("cloud_server_id")
  cloudServer       CloudServer?         @relation(fields: [cloudServerId], references: [id], onDelete: SetNull)
  nodeId            String?              @map("node_id")
  node              Node?                @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  requireGpu        Boolean              @default(false) @map("require_gpu")
  secrets           ProjectSecret[]
  deploys           DeployHistory[]
  steps             WorkflowStep[]
  instances         ContainerInstance[]
  scalingPolicy     ScalingPolicy?
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  @@map("projects")
}

enum InstanceStatus {
  RUNNING
  UNHEALTHY
  STOPPED
}

model ContainerInstance {
  id            String         @id @default(uuid())
  projectId     String         @map("project_id")
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  containerId   String         @map("container_id")
  containerName String         @map("container_name")
  replicaIndex  Int            @map("replica_index")
  status        InstanceStatus @default(RUNNING)
  createdAt     DateTime       @default(now()) @map("created_at")

  @@map("container_instances")
}

model ScalingPolicy {
  id              String    @id @default(uuid())
  projectId       String    @unique @map("project_id")
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  maxCpuPercent   Float     @default(80) @map("max_cpu_percent")
  maxMemPercent   Float     @default(80) @map("max_mem_percent")
  maxResponseMs   Int       @default(2000) @map("max_response_ms")
  minReplicas     Int       @default(1) @map("min_replicas")
  maxReplicas     Int       @default(3) @map("max_replicas")
  cooldownSeconds Int       @default(120) @map("cooldown_seconds")
  scaleEnabled    Boolean   @default(true) @map("scale_enabled")
  lastScaleAt     DateTime? @map("last_scale_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("scaling_policies")
}

model WorkflowStep {
  id        String         @id @default(uuid())
  projectId String         @map("project_id")
  order     Int
  name      String
  type      StepActionType
  command   String         @db.Text
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now()) @map("created_at")

  @@unique([projectId, order])
  @@map("workflow_steps")
}

model ProjectSecret {
  id             String  @id @default(uuid())
  projectId      String  @map("project_id")
  keyName        String  @map("key_name")
  encryptedValue String  @map("encrypted_value")
  project        Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, keyName])
  @@map("project_secrets")
}

model SystemSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model DeployHistory {
  id                String       @id @default(uuid())
  projectId         String       @map("project_id")
  triggeredById     String?      @map("triggered_by_id")
  commitHash        String?      @map("commit_hash")
  commitMsg         String?      @map("commit_msg")
  commitAuthorName  String?      @map("commit_author_name")
  commitAuthorEmail String?      @map("commit_author_email")
  status            DeployStatus @default(RUNNING)
  testsPassed     Int?         @map("tests_passed")
  testsTotal      Int?         @map("tests_total")
  logOutput       Json?        @map("log_output") @db.JsonB
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  triggeredBy     User?        @relation(fields: [triggeredById], references: [id], onDelete: SetNull)
  createdAt       DateTime     @default(now()) @map("created_at")

  @@map("deploy_history")
}

model GatewayRoute {
  id            String   @id @default(uuid())
  name          String
  routePath     String   @unique @map("route_path")
  targetUrl     String   @map("target_url")
  checkPort     Int      @default(0) @map("check_port")
  isActive      Boolean  @default(true) @map("is_active")
  isTunnelled   Boolean  @default(false) @map("is_tunnelled")
  tunnelNodeId  String?  @map("tunnel_node_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("gateway_routes")
}

// ─── Agent / Node Module ──────────────────────────────────────────────────────
enum NodeStatus {
  ONLINE
  OFFLINE
  UPDATING
}

model Node {
  id               String           @id @default(uuid())
  name             String
  os               String
  arch             String
  token            String           @unique
  status           NodeStatus       @default(OFFLINE)
  version          String           @default("v1.0.0")
  ipAddress        String?          @map("ip_address")
  // Geography — ISO-3166-1 alpha-2 country, state/province, city, continent code
  country          String?          // e.g. "BR"
  state            String?          // e.g. "SP"
  city             String?
  continent        String?          // "SA" | "NA" | "EU" | "AP" | "AF" | "OC"
  // GPU hardware capability (null = CPU-only node)
  gpuModel         String?          @map("gpu_model")
  gpuMemoryMb      Int?             @map("gpu_memory_mb")
  gpuCount         Int              @default(0) @map("gpu_count")
  cpuCores         Int              @default(0) @map("cpu_cores")
  ramMb            Int              @default(0) @map("ram_mb")
  // Network transit status: IDLE | STANDBY | STREAMING
  transitStatus    String           @default("IDLE") @map("transit_status")
  // Sonar Pulse — latency to ingress gateway in ms (updated each heartbeat)
  sonarLatencyMs   Float?           @map("sonar_latency_ms")
  // WireGuard mesh
  wireguardPubKey  String?          @map("wireguard_pub_key")
  meshIp           String?          @map("mesh_ip")   // 10.50.x.x assigned by master
  // Tenant ownership — which user registered this node as a provider
  userId           String?          @map("user_id")
  owner            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenantId         String?          @map("tenant_id")
  tenant           Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  // Sprint 17 — Infrastructure type & benchmark quality tier
  infraType        InfraType        @default(SWARM) @map("infra_type")
  benchmarkTier    BenchmarkTier?   @map("benchmark_tier")
  benchmarkScore   Float?           @map("benchmark_score") // composite score 0-100+
  lastBenchmarkAt  DateTime?        @map("last_benchmark_at")
  lastPing         DateTime         @updatedAt @map("last_ping")
  createdAt        DateTime         @default(now()) @map("created_at")
  projects         Project[]
  assignments      NodeAssignment[]
  clusterMembers   ClusterMembership[]
  policy           NodePolicy?
  benchmarks       NodeBenchmark[]

  @@map("nodes")
}

// ─── Node Benchmark Records (Sprint 17.4) ────────────────────────────────────

model NodeBenchmark {
  id            String    @id @default(uuid())
  nodeId        String    @map("node_id")
  node          Node      @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  // 5-stage probe results
  cpuGflops     Float     @default(0) @map("cpu_gflops")       // SHA-256 parallel
  ramGbps       Float     @default(0) @map("ram_gbps")         // block read/write
  storageIops   Float     @default(0) @map("storage_iops")     // random I/O
  gpuTflops     Float     @default(0) @map("gpu_tflops")       // FP16 tensors (0 = no GPU)
  meshLatencyMs Float     @default(0) @map("mesh_latency_ms")  // ping via nexus0
  meshBandwidthMbps Float @default(0) @map("mesh_bandwidth_mbps")
  // Derived
  compositeScore Float    @default(0) @map("composite_score")
  tier          BenchmarkTier @default(BRONZE)
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([nodeId, createdAt])
  @@map("node_benchmarks")
}

// ─── Collective Resource Clusters (Sprint 11) ─────────────────────────────────

model ResourceCluster {
  id            String              @id @default(uuid())
  appId         String              @unique @map("app_id")
  app           DePINApp            @relation(fields: [appId], references: [id], onDelete: Cascade)
  members       ClusterMembership[]
  // Aggregated capacity across all member nodes
  totalVramMb   Int                 @default(0) @map("total_vram_mb")
  totalRamMb    Int                 @default(0) @map("total_ram_mb")
  totalCpuCores Int                 @default(0) @map("total_cpu_cores")
  // WireGuard overlay network
  meshSubnet    String              @default("10.50.0.0/24") @map("mesh_subnet")
  // FORMING | READY | DEGRADED | OFFLINE
  status        String              @default("FORMING")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@map("resource_clusters")
}

model ClusterMembership {
  id        String          @id @default(uuid())
  clusterId String          @map("cluster_id")
  cluster   ResourceCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  nodeId    String          @map("node_id")
  node      Node            @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  meshIp    String          @map("mesh_ip")        // 10.50.0.x assigned within cluster
  role      String          @default("WORKER")     // LEADER | WORKER
  createdAt DateTime        @default(now()) @map("created_at")

  @@unique([clusterId, nodeId])
  @@map("cluster_memberships")
}

// ─── DePIN Execution Layer ────────────────────────────────────────────────────

enum ExecutionMode {
  WASM
  MICROVM
  AUTO
}

enum DePINAppStatus {
  PENDING
  RUNNING
  DEGRADED
  OFFLINE
}

enum AssignmentRole {
  LEADER
  FOLLOWER
  WASM_WORKER
}

enum AssignmentStatus {
  RUNNING
  OFFLINE
  MIGRATING
}

enum SslStatus {
  PENDING
  ACTIVE
  FAILED
}

model DePINApp {
  id             String           @id @default(uuid())
  name           String
  slug           String           @unique
  executionMode  ExecutionMode    @map("execution_mode")
  status         DePINAppStatus   @default(PENDING)
  replicaCount   Int              @default(3) @map("replica_count")
  imageRef       String?          @map("image_ref")
  envVars        Json?            @map("env_vars")
  port           Int?
  region         String?
  customDomain   String?          @unique @map("custom_domain")
  sslStatus      SslStatus?       @map("ssl_status")
  // Sprint 17.1 — live resource allocation (hot-resize via cgroup v2)
  vCpu           Int              @default(0) @map("v_cpu")       // millicores (1000 = 1 vCPU)
  ramMb          Int              @default(0) @map("ram_mb")
  vramMb         Int              @default(0) @map("vram_mb")
  priceMultiplier Float           @default(1.0) @map("price_multiplier")
  // Surge price locked at deploy time — consumer always pays this, provider gets bonus if surge rises
  lockedHourlyUsd Float          @default(0) @map("locked_hourly_usd")
  // Tenant ownership — which user deployed this app as a consumer
  userId         String?          @map("user_id")
  owner          User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenantId       String?          @map("tenant_id")
  tenant         Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  assignments    NodeAssignment[]
  usageRecords   UsageRecord[]
  cluster        ResourceCluster?
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  @@map("depin_apps")
}

model NodeAssignment {
  id        String           @id @default(uuid())
  appId     String           @map("app_id")
  app       DePINApp         @relation(fields: [appId], references: [id], onDelete: Cascade)
  nodeId    String           @map("node_id")
  node      Node             @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  role      AssignmentRole   @default(WASM_WORKER)
  status    AssignmentStatus @default(RUNNING)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@unique([appId, nodeId])
  @@map("node_assignments")
}

// ─── Billing / Proof of Computing ────────────────────────────────────────────

model UsageRecord {
  id                   String   @id @default(uuid())
  appId                String   @map("app_id")
  app                  DePINApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  nodeId               String   @map("node_id")
  windowStart          DateTime @map("window_start")
  windowEnd            DateTime @map("window_end")
  cpuMs                BigInt   @default(0) @map("cpu_ms")
  ramMbS               BigInt   @default(0) @map("ram_mb_s")
  netRxBytes           BigInt   @default(0) @map("net_rx_bytes")
  netTxBytes           BigInt   @default(0) @map("net_tx_bytes")
  // T9.3 — separate transit traffic billed at $netGbTransit/GB
  networkTransitBytes  BigInt   @default(0) @map("network_transit_bytes")
  billedUsd            Float    @default(0) @map("billed_usd")
  // Price locked at deploy time (hedge — consumer is never surprised by surge)
  priceLockedUsd       Float    @default(0) @map("price_locked_usd")
  createdAt            DateTime @default(now()) @map("created_at")

  @@index([appId, windowStart])
  @@index([nodeId, windowStart])
  @@map("usage_records")
}

// ─── Wallet / Ledger ──────────────────────────────────────────────────────────

enum TxType {
  EARN
  SPEND
  DEPOSIT
  WITHDRAW
}

enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model Wallet {
  id           String             @id @default(uuid())
  userId       String             @unique @map("user_id")
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId     String?            @map("tenant_id")
  tenant       Tenant?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  balanceUsd   Float              @default(0) @map("balance_usd")
  earnedUsd    Float              @default(0) @map("earned_usd")   // lifetime Provider earnings
  spentUsd     Float              @default(0) @map("spent_usd")    // lifetime Consumer spend
  updatedAt    DateTime           @updatedAt @map("updated_at")
  transactions LedgerTransaction[]
  payouts      PayoutRequest[]

  @@map("wallets")
}

model LedgerTransaction {
  id          String   @id @default(uuid())
  walletId    String   @map("wallet_id")
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type        TxType
  amountUsd   Float    @map("amount_usd")
  description String?  @db.Text
  metadata    Json?    // { appId, nodeId, windowStart, priceMultiplier }
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([walletId, createdAt])
  @@map("ledger_transactions")
}

model PayoutRequest {
  id          String       @id @default(uuid())
  walletId    String       @map("wallet_id")
  wallet      Wallet       @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amountUsd   Float        @map("amount_usd")
  status      PayoutStatus @default(PENDING)
  pixKey      String?      @map("pix_key")
  notes       String?      @db.Text
  resolvedAt  DateTime?    @map("resolved_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("payout_requests")
}

// ─── Node Policy (Hardware Leash — Sprint 4) ──────────────────────────────────

model NodePolicy {
  id                    String   @id @default(uuid())
  nodeId                String   @unique @map("node_id")
  node                  Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  maxCpuPercent         Float    @default(80)  @map("max_cpu_percent")
  maxRamMb              Int      @default(2048) @map("max_ram_mb")
  maxDiskGb             Int      @default(20)  @map("max_disk_gb")
  maxBandwidthMbps      Int      @default(100) @map("max_bandwidth_mbps")
  scheduleStart         String?  @map("schedule_start")      // "08:00" UTC
  scheduleEnd           String?  @map("schedule_end")        // "22:00" UTC
  offerGpu              Boolean  @default(false) @map("offer_gpu")
  maxGpuPercent         Float    @default(100)  @map("max_gpu_percent")
  offerNetworkTransit   Boolean  @default(false) @map("offer_network_transit")
  transitBandwidthMbps  Int      @default(100)  @map("transit_bandwidth_mbps")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("node_policies")
}

// ─── Audit Trail (Sprint 16 — LGPD compliance) ───────────────────────────────

enum AuditAction {
  BAN
  UNBAN
  MINT
  BURN
  DELETE_USER
  HALT
  CREATE_INVITE
  NODE_TERMINATE
  APP_REMOVE
  BENCHMARK
  STRESS_TEST
}

// ─── Node Infrastructure Classification (Sprint 17) ──────────────────────────

enum InfraType {
  SWARM           // DePIN community node (default)
  CLOUD_MANAGED   // Nexus-owned physical server
  ON_PREMISE      // Enterprise on-prem node
}

enum BenchmarkTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

model AuditLog {
  id         String      @id @default(uuid())
  actorId    String?     @map("actor_id")
  actor      User?       @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     AuditAction
  targetId   String?     @map("target_id")   // userId, nodeId, appId, etc.
  ipAddress  String?     @map("ip_address")
  payload    Json?                             // extra context
  signature  String                            // SHA-256(action+targetId+timestamp)
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Cloud Module ─────────────────────────────────────────────────────────────
enum CloudProviderType {
  AWS
  DIGITALOCEAN
  AZURE
  GCP
}

enum CloudServerStatus {
  PROVISIONING
  RUNNING
  STOPPED
  ERROR
}

model CloudProvider {
  id              String            @id @default(uuid())
  name            String
  type            CloudProviderType
  encryptedApiKey String            @map("encrypted_api_key")
  region          String
  servers         CloudServer[]
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@map("cloud_providers")
}

model CloudServer {
  id             String            @id @default(uuid())
  providerId     String            @map("provider_id")
  provider       CloudProvider     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  name           String
  region         String
  instanceType   String            @map("instance_type")
  ip             String?
  status         CloudServerStatus @default(PROVISIONING)
  agentConnected Boolean           @default(false) @map("agent_connected")
  agentVersion   String?           @map("agent_version")
  sshPublicKey   String?           @db.Text @map("ssh_public_key")
  lastError      String?           @db.Text @map("last_error")
  projects       Project[]
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  @@map("cloud_servers")
}
