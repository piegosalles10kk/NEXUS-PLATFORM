# ── NEXUS PLATFORM — ENVIRONMENT VARIABLES ────────────────────────────────────
# Copie este arquivo para .env e ajuste os valores conforme o ambiente.
# Dev local  → hosts: 127.0.0.1 / localhost
# Produção   → hosts: nomes dos containers Docker (10kk-postgres, 10kk-redis…)

# ── NODE ENVIRONMENT ──────────────────────────────────────────────────────────
NODE_ENV=production          # development | production
PORT=4500

# ── DATABASE (PostgreSQL) ─────────────────────────────────────────────────────
POSTGRES_USER=nexus_admin
POSTGRES_PASSWORD=Inbox@2026
POSTGRES_DB=nexus_db

# Dev local  → @127.0.0.1:5432  (use 127.0.0.1, não localhost — evita P1001 no Windows)
# Produção   → @10kk-postgres:5432
# ATENÇÃO: caracteres especiais na senha devem ser percent-encoded (@  →  %40)
DATABASE_URL=postgresql://nexus_admin:Inbox%402026@10kk-postgres:5432/nexus_db

# ── CACHE & RATE LIMIT (Redis) ────────────────────────────────────────────────
# Dev local  → redis://localhost:6379
# Produção   → redis://10kk-redis:6379
REDIS_URL=redis://10kk-redis:6379

# ── SECURITY ──────────────────────────────────────────────────────────────────
# JWT Secret — use uma string aleatória longa em produção
JWT_SECRET=your_long_random_jwt_secret_here

# Chave AES-256-GCM para criptografia de secrets — EXATAMENTE 64 hex chars (32 bytes)
# Gere com: openssl rand -hex 32
ENCRYPTION_KEY=e1357eaa3a1ca199d708b9580f0c40811316b1df6e55d5404248c3360cfb2713

# Secret HMAC-SHA256 para validar webhooks do GitHub
GITHUB_WEBHOOK_SECRET=b613679a0814d9ec772f95d778c35fc5ff1697c493715653c6c712144292c5ad

# ── GEMINI AI ─────────────────────────────────────────────────────────────────
# Obtenha em https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── NETWORKING ────────────────────────────────────────────────────────────────
# URL pública do frontend — usada para CORS e Socket.io
# Dev local  → http://localhost:8000
# Produção   → https://piegosalles-backend.cloud
FRONTEND_URL=https://piegosalles-backend.cloud

# Porta do servidor WebSocket mTLS para agentes
AGENT_WS_PORT=8443

# Docker Socket Proxy
# Dev local  → tcp://localhost:2375
# Produção   → tcp://10kk-docker-proxy:2375
DOCKER_PROXY_HOST=tcp://10kk-docker-proxy:2375

# Host usado para checar portas disponíveis
# Dev local  → localhost
# Produção   → host.docker.internal
PORT_CHECK_HOST=host.docker.internal

# ── FRONTEND (build time) ─────────────────────────────────────────────────────
# URL pública da API (incluindo /api)
# Dev local  → http://localhost:4500/api
# Produção   → https://piegosalles-backend.cloud/api
VITE_API_URL=https://piegosalles-backend.cloud/api

# ── EMAIL (opcional — reset de senha) ────────────────────────────────────────
EMAIL_USER=
EMAIL_PASS=
